{
  "name": "ttv-lol-pro",
  "version": "2.6.2",
  "description": "TTV LOL PRO removes most livestream ads from Twitch.",
  "keywords": [
    "twitch",
    "web-extension",
    "adblocker"
  ],
  "homepage": "https://github.com/younesaassila/ttv-lol-pro#readme",
  "bugs": {
    "url": "https://github.com/younesaassila/ttv-lol-pro/issues"
  },
  "license": "GPL-3.0",
  "author": "Younes Aassila (https://github.com/younesaassila)",
  "contributors": [
    "Marc Gómez (https://github.com/zGato)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/younesaassila/ttv-lol-pro.git"
  },
  "scripts": {
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "type-check": "tsc --noEmit",
    "clean": "shx rm -rf .parcel-cache ; shx rm -rf dist ; shx --silent rm src/manifest.json ; exit 0",
    "predev:firefox": "npm run clean && shx cp src/manifest.firefox.json src/manifest.json",
    "predev:chromium": "npm run clean && shx cp src/manifest.chromium.json src/manifest.json",
    "dev:firefox": "parcel watch --target webext-dev --no-hmr",
    "dev:chromium": "parcel watch --target webext-dev --no-hmr",
    "prebuild:firefox": "npm run clean && shx cp src/manifest.firefox.json src/manifest.json",
    "prebuild:chromium": "npm run clean && shx cp src/manifest.chromium.json src/manifest.json",
    "build:firefox": "parcel build --target webext-prod",
    "build:chromium": "parcel build --target webext-prod"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "bowser": "^2.13.1",
    "ip-address": "^10.1.0",
    "m3u8-parser": "^7.2.0"
  },
  "devDependencies": {
    "@parcel/config-webextension": "^2.16.3",
    "@types/chrome": "^0.1.32",
    "@types/node": "^24.10.1",
    "@types/webextension-polyfill": "^0.12.4",
    "buffer": "^6.0.3",
    "parcel": "^2.16.3",
    "prettier": "3.6.2",
    "prettier-plugin-css-order": "2.1.2",
    "prettier-plugin-organize-imports": "4.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.3",
    "webextension-polyfill": "^0.12.0"
  },
  "source": "src/manifest.json",
  "targets": {
    "webext-dev": {},
    "webext-prod": {
      "sourceMap": false
    }
  },
  "@parcel/bundler-default": {
    "minBundles": 10000000,
    "minBundleSize": 3000,
    "maxParallelRequests": 20
  },
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "private": true
}
